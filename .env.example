# EarnHub Environment Variables
# Copy this file to .env and fill in your actual API keys

# CPX Research
VITE_CPX_APP_ID=your_cpx_app_id_here
VITE_CPX_SECURITY_HASH=your_cpx_security_hash_here

# AdGate Media
VITE_ADGATE_APP_ID=your_adgate_app_id_here

# OfferToro
VITE_OFFERTORO_APP_ID=your_offertoro_app_id_here
VITE_OFFERTORO_SECRET=your_offertoro_secret_here

# App Config
VITE_APP_USER_ID=your_unique_user_id_here
VITE_APP_NAME=EarnHub
