# EarnHub Server — Environment Variables
# Copy to .env and fill in real values

# MongoDB Atlas connection string
# Get from: Atlas Dashboard → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/earnhub?retryWrites=true&w=majority

# JWT secret — make this long and random
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret

# JWT expiry
JWT_EXPIRES_IN=7d

# Server port
PORT=5000

# Frontend origin (for CORS)
CLIENT_ORIGIN=http://localhost:3000
